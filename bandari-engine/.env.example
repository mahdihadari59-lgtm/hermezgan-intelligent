PORT=5200
LOG_LEVEL=info

# LLM - llama.cpp (Local)
BANDARI_LLM_ENABLED=1
LLM_PROVIDER=llama.cpp
LLM_API_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_MODEL=Qwen2.5-1.5B-Instruct-Q4_K_M
LLM_TIMEOUT=30000
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=256

