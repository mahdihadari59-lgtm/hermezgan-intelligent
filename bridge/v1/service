# -*- coding: utf-8 -*-

"""
bridge/v1/bridge_service.py

High Level Bridge Service
"""

from database_bridge import DatabaseBridge
from config import GEO_DB
from config import HDP_DB


class BridgeService:

    def __init__(
        self,
        geo_db=GEO_DB,
        knowledge_db=HDP_DB,
    ):

        self.bridge = DatabaseBridge(
            geo_db,
            knowledge_db,
        )

    # =====================================================

    def __enter__(self):

        self.bridge.connect()

        return self

    def __exit__(
        self,
        exc_type,
        exc,
        tb,
    ):

        self.bridge.close()

    # =====================================================
    # STATUS
    # =====================================================

    def status(self):

        return self.bridge.status()

    def tables(
        self,
        schema="main",
    ):

        return self.bridge.tables(schema)

    def health(self):

        return self.bridge.health()

    # =====================================================
    # SEARCH
    # =====================================================

    def search(
        self,
        keyword,
    ):

        return self.bridge.search_everywhere(
            keyword
        )

    def search_entity(
        self,
        keyword,
    ):

        return self.bridge.find_entity(
            keyword
        )

    def search_place(
        self,
        keyword,
    ):

        return self.bridge.find_place(
            keyword
        )

    def search_relation(
        self,
        keyword,
    ):

        return self.bridge.find_relation(
            keyword
        )

    # =====================================================
    # QUERY
    # =====================================================

    def query(
        self,
        sql,
        params=(),
    ):

        return self.bridge.query(
            sql,
            params,
        )

    def execute(
        self,
        sql,
        params=(),
    ):

        return self.bridge.execute(
            sql,
            params,
        )

    def fetchone(
        self,
        sql,
        params=(),
    ):

        return self.bridge.fetchone(
            sql,
            params,
        )

    def fetchall(
        self,
        sql,
        params=(),
    ):

        return self.bridge.fetchall(
            sql,
            params,
        )

    def fetchdict(
        self,
        sql,
        params=(),
    ):

        return self.bridge.fetchdict(
            sql,
            params,
        )

    # =====================================================
    # JOIN
    # =====================================================

    def join_tables(
        self,
        left_table,
        right_table,
        left_column,
        right_column,
        columns="*",
        left_schema="main",
        right_schema="knowledge",
        where=None,
        params=(),
    ):

        return self.bridge.join_tables(
            left_table,
            right_table,
            left_column,
            right_column,
            columns,
            left_schema,
            right_schema,
            where,
            params,
        )

    def hospital_knowledge(self):

        return self.bridge.hospital_knowledge()

    def place_knowledge(
        self,
        table,
        column="name",
    ):

        return self.bridge.place_knowledge(
            table,
            column,
        )


# =====================================================
# FACTORY
# =====================================================

_bridge_instance = None


def create_service(
    geo_db=GEO_DB,
    knowledge_db=HDP_DB,
):

    service = BridgeService(
        geo_db,
        knowledge_db,
    )

    return service


def get_service():

    global _bridge_instance

    if _bridge_instance is None:

        _bridge_instance = BridgeService()

    return _bridge_instance


def open_service():

    service = BridgeService()

    service.bridge.connect()

    return service


# =====================================================
# WRAPPER API
# =====================================================

def search(keyword):

    with BridgeService() as service:

        return service.search(keyword)


def search_entity(keyword):

    with BridgeService() as service:

        return service.search_entity(keyword)


def search_place(keyword):

    with BridgeService() as service:

        return service.search_place(keyword)


def status():

    with BridgeService() as service:

        return service.status()


def tables(schema="main"):

    with BridgeService() as service:

        return service.tables(schema)


